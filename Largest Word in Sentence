#include<stdio.h>
#include<string.h>

int main()
{
    char str[100],word[20],max[20];
    int i=0,j=0;

    fgets(str,100,stdin);

    while(1)
    {
        if(str[i]==' ' || str[i]=='\0')
        {
            word[j]='\0';

            if(strlen(word)>strlen(max))
                strcpy(max,word);

            j=0;

            if(str[i]=='\0')
                break;
        }
        else
        {
            word[j++]=str[i];
        }

        i++;
    }

    printf("Largest word=%s",max);
}
