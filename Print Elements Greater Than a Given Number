#include <stdio.h>
int main() {
    int a[5], i, num;

    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

    printf("Enter number: ");
    scanf("%d",&num);

    printf("Elements greater than %d:\n",num);

    for(i=0;i<5;i++){
        if(a[i] > num)
            printf("%d ",a[i]);
    }

    return 0;
}
