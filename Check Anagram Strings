#include<stdio.h>
#include<string.h>

int main()
{
    char s1[100],s2[100];
    int i,j,count=0;

    scanf("%s%s",s1,s2);

    if(strlen(s1)!=strlen(s2))
    {
        printf("Not Anagram");
        return 0;
    }

    for(i=0;s1[i]!='\0';i++)
    {
        count=0;
        for(j=0;s2[j]!='\0';j++)
        {
            if(s1[i]==s2[j])
            {
                count=1;
                break;
            }
        }

        if(count==0)
        {
            printf("Not Anagram");
            return 0;
        }
    }

    printf("Anagram");
}
