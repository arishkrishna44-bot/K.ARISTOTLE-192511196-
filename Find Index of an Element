#include <stdio.h>
int main() {
    int a[5], i, key;

    for(i=0;i<5;i++)
        scanf("%d",&a[i]);

    printf("Enter element to find: ");
    scanf("%d",&key);

    for(i=0;i<5;i++){
        if(a[i] == key){
            printf("Index = %d",i);
            return 0;
        }
    }

    printf("Element not found");
    return 0;
}
